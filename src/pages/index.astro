---
import "../styles/global.css";
import { Game } from "@/components/Game";
import { Navbar } from "@/components/Navbar";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/knowyourai/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>KnowYourAI - AI Icon Quiz</title>
    <meta name="description" content="Can you match AI company logos to their names? Test your knowledge of 58 AI company icons." />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KnowYourAI" />
    <meta property="og:url" content="https://jagreehal.github.io/knowyourai/" />
    <meta property="og:title" content="KnowYourAI - How well do you know AI?" />
    <meta property="og:description" content="58 AI company logos. One shot each. No second guesses. Can you name them all?" />
    <meta property="og:image" content="https://jagreehal.github.io/knowyourai/og.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://jagreehal.github.io/knowyourai/" />
    <meta name="twitter:title" content="KnowYourAI - How well do you know AI?" />
    <meta name="twitter:description" content="58 AI company logos. One shot each. No second guesses. Can you name them all?" />
    <meta name="twitter:image" content="https://jagreehal.github.io/knowyourai/og.svg" />
  </head>
  <body class="min-h-screen bg-[#f9fafb] dark:bg-zinc-950 overflow-x-hidden flex flex-col">
    <div class="grain-overlay"></div>
    <Navbar client:load />
    <div class="flex-1 pt-16">
      <Game client:load />
    </div>
    <footer class="relative z-10 py-6 text-center text-xs text-zinc-400 dark:text-zinc-600">
      Icons sourced from
      <a
        href="https://github.com/lobehub/lobe-icons"
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors"
      >
        lobe-icons
      </a>
    </footer>
  </body>
</html>
