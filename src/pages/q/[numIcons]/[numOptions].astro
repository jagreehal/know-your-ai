---
import "../../../styles/global.css";
import { Game } from "@/components/Game";
import { Navbar } from "@/components/Navbar";
import { ICONS } from "@/data/icons";

export function getStaticPaths() {
  const iconCounts = [10, 20, 30, 40, ICONS.length];
  const optionCounts = [3, 4, 5];
  const paths = [];
  for (const q of iconCounts) {
    for (const o of optionCounts) {
      paths.push({ params: { numIcons: String(q), numOptions: String(o) } });
    }
  }
  return paths;
}

const { numIcons, numOptions } = Astro.params;
const q = parseInt(numIcons || "10", 10);
const o = parseInt(numOptions || "4", 10);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/knowyourai/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>KnowYourAI - {q} logos, {o} choices</title>
    <meta name="description" content={`Think you know AI? Guess ${q} company logos with ${o} choices each. Same logos as your challenger.`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KnowYourAI" />
    <meta property="og:url" content={`https://jagreehal.github.io/knowyourai/q/${q}/${o}`} />
    <meta property="og:title" content={`KnowYourAI Challenge - ${q} logos, ${o} choices`} />
    <meta property="og:description" content={`Someone challenged you to guess ${q} AI company logos with ${o} choices each. Same logos. Think you can beat them?`} />
    <meta property="og:image" content="https://jagreehal.github.io/knowyourai/og.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`https://jagreehal.github.io/knowyourai/q/${q}/${o}`} />
    <meta name="twitter:title" content={`KnowYourAI Challenge - ${q} logos, ${o} choices`} />
    <meta name="twitter:description" content={`Someone challenged you to guess ${q} AI company logos with ${o} choices each. Same logos. Think you can beat them?`} />
    <meta name="twitter:image" content="https://jagreehal.github.io/knowyourai/og.svg" />
  </head>
  <body class="min-h-screen bg-[#f9fafb] dark:bg-zinc-950 overflow-x-hidden flex flex-col">
    <div class="grain-overlay"></div>
    <Navbar client:load />
    <div class="flex-1 pt-16">
      <div id="game-root" data-q={q} data-o={o}>
        <Game client:load />
      </div>
    </div>
    <footer class="relative z-10 py-6 text-center text-xs text-zinc-400 dark:text-zinc-600">
      Icons sourced from
      <a
        href="https://github.com/lobehub/lobe-icons"
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors"
      >
        lobe-icons
      </a>
    </footer>
    <script is:inline>
      (function() {
        var root = document.getElementById("game-root");
        var seed = new URLSearchParams(window.location.search).get("seed") || "";
        if (seed && root) {
          root.dataset.seed = seed;
        }
      })();
    </script>
  </body>
</html>
